# ==============================
# WA Blast UPJ — Environment Variables
# ==============================

# --- Database ---
# PostgreSQL connection string (install Postgres langsung di VPS, bukan cloud)
DATABASE_URL="postgresql://user:password@localhost:5432/wablast_upj?schema=public"

# --- Redis ---
# Redis connection untuk BullMQ job queue
REDIS_URL="redis://localhost:6379"

# --- NextAuth ---
# Secret untuk enkripsi session (generate dengan: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-me-with-openssl-rand-base64-32"
# URL aplikasi (ganti dengan domain asli saat deploy)
NEXTAUTH_URL="http://localhost:3000"

# --- WhatsApp API ---
# API Key dari provider WhatsApp (Fonnte/Wablas/dll)
WA_API_KEY="your-whatsapp-api-key"
# Base URL endpoint provider WhatsApp
WA_API_BASE_URL="https://api.example.com"
# Delay antar pengiriman pesan (dalam milidetik) untuk menghindari blokir
BLAST_DELAY_MS="4000"

# --- Admin Seed ---
# Kredensial admin default (digunakan saat prisma db seed)
# UBAH password setelah deploy!
ADMIN_SEED_EMAIL="admin@upj.ac.id"
ADMIN_SEED_PASSWORD="Admin123!"
ADMIN_SEED_NAME="Admin UPJ"
