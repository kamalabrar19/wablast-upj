import { getServerSession } from "next-auth";
import { redirect } from "next/navigation";
import { authOptions } from "@/lib/auth";
import { prisma } from "@/lib/db";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Users, Send, CheckCircle2, XCircle } from "lucide-react";

export default async function DashboardPage() {
  const session = await getServerSession(authOptions);

  if (!session?.user) {
    redirect("/login");
  }

  const [
    totalContacts,
    totalBlastsThisMonth,
    blastStats,
  ] = await Promise.all([
    prisma.contact.count({
      where: { createdById: session.user.id },
    }),
    prisma.blast.count({
      where: {
        createdById: session.user.id,
        createdAt: {
          gte: new Date(new Date().getFullYear(), new Date().getMonth(), 1),
        },
      },
    }),
    prisma.blastTarget.aggregate({
      _count: true,
      where: {
        blast: {
          createdById: session.user.id,
        },
      },
    }),
  ]);

  const successRate = blastStats._count > 0
    ? Math.round(
        (await prisma.blastTarget.count({
          where: {
            blast: { createdById: session.user.id },
            status: { in: ["sent", "read"] },
          },
        })) /
          blastStats._count *
          100
      )
    : 0;

  return (
    <div className="space-y-8">
      <div>
        <h1 className="text-2xl font-bold text-white">Dashboard</h1>
        <p className="mt-1 text-sm text-slate-400">
          Selamat datang, {session.user.name}
        </p>
      </div>

      <div className="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <Card>
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium text-slate-400">
              Total Kontak
            </CardTitle>
            <Users className="h-4 w-4 text-whatsapp" />
          </CardHeader>
          <CardContent>
            <p className="text-3xl font-bold text-white">{totalContacts}</p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium text-slate-400">
              Blast Bulan Ini
            </CardTitle>
            <Send className="h-4 w-4 text-blue-400" />
          </CardHeader>
          <CardContent>
            <p className="text-3xl font-bold text-white">
              {totalBlastsThisMonth}
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium text-slate-400">
              Tingkat Keberhasilan
            </CardTitle>
            <CheckCircle2 className="h-4 w-4 text-emerald-400" />
          </CardHeader>
          <CardContent>
            <p className="text-3xl font-bold text-white">{successRate}%</p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium text-slate-400">
              Total Terkirim
            </CardTitle>
            <XCircle className="h-4 w-4 text-amber-400" />
          </CardHeader>
          <CardContent>
            <p className="text-3xl font-bold text-white">
              {blastStats._count}
            </p>
          </CardContent>
        </Card>
      </div>
    </div>
  );
}
